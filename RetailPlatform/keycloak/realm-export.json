{
  "realm": "retailplatform",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 3600,
  "roles": {
    "realm": [
      { "name": "user", "description": "Standard user" },
      { "name": "admin", "description": "Administrator" }
    ]
  },
  "clients": [
    {
      "clientId": "retailplatform-api",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "retailplatform-client",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-secret-change-me",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["http://localhost:50000/*"],
      "webOrigins": ["http://localhost:50000"],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "emailVerified": true,
      "email": "testuser@retailplatform.local",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "Test123!",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    },
    {
      "username": "adminuser",
      "enabled": true,
      "emailVerified": true,
      "email": "adminuser@retailplatform.local",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "Admin123!",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "admin"]
    }
  ]
}